{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dfine.io/schemas/secret-patterns.schema.json",
  "title": "dlint secret patterns",
  "description": "Public, deterministic credential-format patterns consumed by the dlint no-secrets rule.",
  "type": "object",
  "required": ["version", "patterns"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "description": "Pattern-set version (refreshed ~every 4 weeks)."
    },
    "source": {
      "type": "string",
      "description": "Upstream provenance + commit."
    },
    "license": { "type": "string" },
    "denylist": {
      "type": "array",
      "description": "Literal values that match a pattern but are documented examples (suppressed).",
      "items": { "type": "string" }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "regex"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string" },
          "regex": {
            "type": "string",
            "description": "JS-compatible, ReDoS-checked regular expression."
          },
          "confidence": { "enum": ["high", "medium", "low"] },
          "examples": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "match": { "type": "array", "items": { "type": "string" } },
              "noMatch": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
