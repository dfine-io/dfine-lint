{
  "version": "2026.06.17",
  "source": "Curated high-confidence subset forked from gitleaks (github.com/gitleaks/gitleaks, MIT, (c) 2019 Zachary Rice). Regex-deterministic vendor formats only: distinctive prefixes, no entropy, bounded quantifiers (ReDoS-safe). See THIRD-PARTY-LICENSES.",
  "license": "MIT",
  "denylist": [
    "AKIAIOSFODNN7EXAMPLE",
    "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
  ],
  "patterns": [
    {
      "id": "aws-access-key-id",
      "description": "AWS Access Key ID",
      "confidence": "high",
      "regex": "\\b(?:AKIA|ASIA|AGPA|AIDA|AROA|ANPA|AIPA)[0-9A-Z]{16}\\b",
      "examples": { "match": ["AKIAABCDEFGHIJKLMNOP"], "noMatch": ["AKIASHORT", "akiaabcdefghijklmnop"] }
    },
    {
      "id": "github-pat",
      "description": "GitHub Personal Access Token",
      "confidence": "high",
      "regex": "\\bghp_[0-9A-Za-z]{36}\\b",
      "examples": { "match": ["ghp_abcdefghijklmnopqrstuvwxyz0123456789"], "noMatch": ["ghp_short"] }
    },
    {
      "id": "github-oauth-token",
      "description": "GitHub OAuth Access Token",
      "confidence": "high",
      "regex": "\\bgho_[0-9A-Za-z]{36}\\b",
      "examples": { "match": ["gho_abcdefghijklmnopqrstuvwxyz0123456789"], "noMatch": ["gho_short"] }
    },
    {
      "id": "gitlab-pat",
      "description": "GitLab Personal Access Token",
      "confidence": "high",
      "regex": "\\bglpat-[0-9A-Za-z_-]{20}\\b",
      "examples": { "match": ["glpat-abcdefghij0123456789"], "noMatch": ["glpat-short"] }
    },
    {
      "id": "stripe-secret-key",
      "description": "Stripe Live Secret Key",
      "confidence": "high",
      "regex": "\\b(?:sk|rk)_live_[0-9A-Za-z]{24,256}\\b",
      "examples": { "match": ["sk_live_abcdefghijklmnopqrstuvwx"], "noMatch": ["sk_live_short", "sk_test_abcdefghijklmnopqrstuvwx"] }
    },
    {
      "id": "google-api-key",
      "description": "Google API Key",
      "confidence": "high",
      "regex": "\\bAIza[0-9A-Za-z_-]{35}\\b",
      "examples": { "match": ["AIzaabcdefghijklmnopqrstuvwxyz012345678"], "noMatch": ["AIzashort"] }
    },
    {
      "id": "slack-token",
      "description": "Slack Token",
      "confidence": "high",
      "regex": "\\bxox[baprs]-[0-9A-Za-z-]{10,256}\\b",
      "examples": { "match": ["xoxb-abcdef1234567890"], "noMatch": ["xoxb-1"] }
    },
    {
      "id": "npm-access-token",
      "description": "npm Access Token",
      "confidence": "high",
      "regex": "\\bnpm_[0-9A-Za-z]{36}\\b",
      "examples": { "match": ["npm_abcdefghijklmnopqrstuvwxyz0123456789"], "noMatch": ["npm_short"] }
    },
    {
      "id": "sendgrid-api-key",
      "description": "SendGrid API Key",
      "confidence": "high",
      "regex": "\\bSG\\.[0-9A-Za-z_-]{22}\\.[0-9A-Za-z_-]{43}\\b",
      "examples": { "match": ["SG.abcdefghijklmnopqrstuv.abcdefghijklmnopqrstuvwxyz01234567890123456"], "noMatch": ["SG.short.short"] }
    },
    {
      "id": "private-key-pem",
      "description": "Private Key (PEM)",
      "confidence": "high",
      "regex": "-----BEGIN (?:RSA |EC |OPENSSH |DSA |PGP |ENCRYPTED )?PRIVATE KEY-----",
      "examples": { "match": ["-----BEGIN RSA PRIVATE KEY-----", "-----BEGIN PRIVATE KEY-----"], "noMatch": ["-----BEGIN CERTIFICATE-----"] }
    }
  ]
}
